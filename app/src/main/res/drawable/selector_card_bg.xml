        <shape android:shape="rectangle">
            <solid android:color="#0D1117" />
            <stroke android:color="#91DBE4" android:width="2dp" />
            <corners android:radius="10dp" />
        </shape>
    </item>
    <item android:state_selected="true">
        <shape android:shape="rectangle">
            <solid android:color="#0D1117" />
            <stroke android:color="#91DBE4" android:width="2dp" />
            <corners android:radius="10dp" />
